# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_TIMEOUT_SECONDS=60
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=

# Document Extraction Limits
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
DOCUMENT_MAX_PAGES=20
DOCUMENT_MIN_TEXT_LENGTH=50

# PostgreSQL (async with pgvector)
DATABASE_ASYNC_URL=postgresql+asyncpg://opositaria:opositaria_dev@localhost:5433/opositaria

# RabbitMQ
RABBITMQ_URL=amqp://opositaria:opositaria_dev@localhost:5673/

# Document Storage
DOCUMENT_STORAGE_PATH=./data/documents

# Embedding Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Semantic Search Limits
SEARCH_DEFAULT_LIMIT=10
SEARCH_MAX_LIMIT=50

# Processing Limits
PROCESSING_MAX_PDF_SIZE_BYTES=52428800
PROCESSING_MAX_CHUNK_COUNT=500
